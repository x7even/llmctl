# Secrets and runtime state — never commit
config/mcp.json
.env
*.pid
*.log
logs/

# vLLM/Triton compilation caches — large, machine-specific, regenerated on first boot
.vllm-cache/
.triton-cache/

# Built/downloaded binaries
bin/llama-swap
bin/llama-swap-ui
bin/llmpanel
tui/tui

# Python cache
__pycache__/
*.pyc
*.pyo

# Model files (live at /mnt/models/llm, not here)
*.gguf
*.safetensors
*.bin

# Editor / OS noise
.DS_Store
*.swp
*~
