#!/usr/bin/env python3
# Install: ln -sf "$(pwd)/bin/llmproxy" ~/.local/bin/llmproxy
#
# Workaround proxy: fixes vLLM streaming tool_call chunks for @ai-sdk/openai-compatible.
#
# Root cause: vLLM sends {"function": {"name": null}} in follow-on SSE chunks and
# sometimes omits the name entirely for parallel tool calls (index > 0).
# @ai-sdk validates typeof name === 'string' on every chunk — null and undefined
# both fail.
#
# Strategy: buffer chunks per unknown tool_call index until the real name arrives
# (or a sibling index provides a fallback), then flush with name restored.
#
# Remove once vLLM fixes null-name serialisation upstream.
# Track: https://github.com/vllm-project/vllm/issues — search "tool_call name null streaming"

import http.server
import json
import sys
import urllib.error
import urllib.request
from pathlib import Path

UPSTREAM = "http://127.0.0.1:8080"
DEFAULT_PORT = 9000
DEBUG_LOG = Path.home() / ".local/share/llmstack/llmproxy-debug.log"
LOOKAHEAD = 32   # max chunks to buffer per unknown-named tool call


def _dbg(msg: str) -> None:
    with open(DEBUG_LOG, "a") as f:
        f.write(msg + "\n")


def _parse_tool_calls(line: str):
    """Return (data_dict, tool_calls_list) or (None, []) if line isn't a tool_call chunk."""
    if not line.startswith("data: "):
        return None, []
    payload = line[6:]
    if payload.strip() == "[DONE]":
        return None, []
    try:
        data = json.loads(payload)
    except json.JSONDecodeError:
        return None, []
    tcs = []
    for choice in data.get("choices", []):
        tcs.extend(choice.get("delta", {}).get("tool_calls", []))
    return data, tcs


def _apply_names(data: dict, tool_names: dict) -> tuple[str, bool]:
    """Patch null names in data using tool_names. Returns (line, patched)."""
    patched = False
    for choice in data.get("choices", []):
        for tc in choice.get("delta", {}).get("tool_calls", []):
            fn = tc.get("function")
            if not isinstance(fn, dict):
                continue
            idx = tc.get("index", 0)
            name = fn.get("name")
            if name is not None:
                tool_names[idx] = name
                _dbg(f"NAME_SET idx={idx} name={name!r}")
            elif "name" in fn:
                if idx in tool_names:
                    fn["name"] = tool_names[idx]
                    _dbg(f"NAME_RESTORED idx={idx} name={tool_names[idx]!r}")
                    patched = True
                else:
                    # No name for this index yet — caller handles buffering
                    _dbg(f"NAME_UNKNOWN idx={idx}")
                    return None, False   # signal: needs buffering
    return ("data: " + json.dumps(data, separators=(",", ":"))) if patched else ("data: " + json.dumps(data, separators=(",", ":"))), True


def _process_line(line: str, tool_names: dict) -> str | None:
    """Return patched line, or None if the line needs to be buffered."""
    data, tcs = _parse_tool_calls(line)
    if data is None:
        return line   # not a tool_call chunk, pass through
    if not tcs:
        return line

    needs_buffer = False
    for tc in tcs:
        fn = tc.get("function")
        if isinstance(fn, dict) and "name" in fn and fn.get("name") is None:
            idx = tc.get("index", 0)
            if idx not in tool_names:
                needs_buffer = True

    if needs_buffer:
        return None

    patched = False
    for tc in tcs:
        fn = tc.get("function")
        if not isinstance(fn, dict):
            continue
        idx = tc.get("index", 0)
        name = fn.get("name")
        if name is not None:
            tool_names[idx] = name
            _dbg(f"NAME_SET idx={idx} name={name!r}")
        elif "name" in fn:
            if idx in tool_names:
                fn["name"] = tool_names[idx]
                _dbg(f"NAME_RESTORED idx={idx} name={tool_names[idx]!r}")
                patched = True
    return ("data: " + json.dumps(data, separators=(",", ":"))) if patched else line


def _flush_buffered(pending: list, tool_names: dict) -> list:
    """Apply now-known names to buffered lines. Returns lines ready to write."""
    out = []
    for line in pending:
        data, tcs = _parse_tool_calls(line)
        if data is None or not tcs:
            out.append(line)
            continue
        patched = False
        for tc in tcs:
            fn = tc.get("function")
            if not isinstance(fn, dict):
                continue
            idx = tc.get("index", 0)
            if "name" in fn and fn.get("name") is None:
                if idx in tool_names:
                    fn["name"] = tool_names[idx]
                    _dbg(f"NAME_FLUSHED idx={idx} name={tool_names[idx]!r}")
                    patched = True
                else:
                    # Still unknown — use any known name as fallback
                    fallback = next(iter(tool_names.values()), None)
                    if fallback:
                        fn["name"] = fallback
                        tool_names[idx] = fallback
                        _dbg(f"NAME_FALLBACK idx={idx} name={fallback!r}")
                        patched = True
                    else:
                        del fn["name"]
                        _dbg(f"NAME_FORCED_DELETE idx={idx}")
                        patched = True
        out.append(("data: " + json.dumps(data, separators=(",", ":"))) if patched else line)
    return out


class _Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass

    def _proxy(self):
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length) if length else None
        headers = {k: v for k, v in self.headers.items()
                   if k.lower() not in ("host", "content-length", "transfer-encoding")}
        if body:
            headers["Content-Length"] = str(len(body))
        req = urllib.request.Request(
            UPSTREAM + self.path, data=body, headers=headers, method=self.command
        )
        try:
            resp = urllib.request.urlopen(req, timeout=660)
        except urllib.error.HTTPError as e:
            resp = e
        self.send_response(resp.status)
        streaming = False
        for k, v in resp.headers.items():
            if k.lower() == "transfer-encoding":
                continue
            self.send_header(k, v)
            if k.lower() == "content-type" and "event-stream" in v:
                streaming = True
        self.end_headers()
        if streaming:
            tool_names: dict = {}
            pending: list = []   # buffered lines awaiting a name for unknown indices
            buf = b""
            while True:
                chunk = resp.read(256)
                if not chunk:
                    break
                buf += chunk
                while b"\n" in buf:
                    raw_line, buf = buf.split(b"\n", 1)
                    line = raw_line.decode("utf-8", errors="replace").rstrip("\r")

                    # First scan for any name-sets in this line to unblock pending
                    _, tcs = _parse_tool_calls(line)
                    for tc in tcs:
                        fn = tc.get("function")
                        if isinstance(fn, dict):
                            name = fn.get("name")
                            if name is not None:
                                tool_names[tc.get("index", 0)] = name

                    # Flush any previously buffered lines that now have names
                    if pending:
                        for flushed in _flush_buffered(pending, tool_names):
                            self.wfile.write((flushed + "\n").encode())
                            self.wfile.flush()
                        pending.clear()

                    result = _process_line(line, tool_names)
                    if result is None:
                        # Name still unknown — buffer it, but cap buffer size
                        pending.append(line)
                        if len(pending) >= LOOKAHEAD:
                            for flushed in _flush_buffered(pending, tool_names):
                                self.wfile.write((flushed + "\n").encode())
                                self.wfile.flush()
                            pending.clear()
                    else:
                        self.wfile.write((result + "\n").encode())
                        self.wfile.flush()

            # Flush any remaining buffered lines at end of stream
            if pending:
                for flushed in _flush_buffered(pending, tool_names):
                    self.wfile.write((flushed + "\n").encode())
                    self.wfile.flush()
            if buf:
                line = buf.decode("utf-8", errors="replace").rstrip("\r")
                self.wfile.write((_process_line(line, tool_names) or line + "\n").encode())
                self.wfile.flush()
        else:
            self.wfile.write(resp.read())

    do_GET = do_POST = do_PUT = do_DELETE = _proxy


def main():
    port = int(sys.argv[1]) if len(sys.argv) > 1 else DEFAULT_PORT
    server = http.server.ThreadingHTTPServer(("127.0.0.1", port), _Handler)
    print(f"llmproxy :{port} → {UPSTREAM}  (Ctrl-C to stop)", flush=True)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
