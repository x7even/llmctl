# DEPRECATED — locally-built vLLM image (broken with transformers 5.x)
#
# This image (vLLM 0.10.2rc1, ROCm 7.1.1) is no longer used. Transformers 5.x
# removed `all_special_tokens_extended`, causing an AttributeError on all Qwen3
# models at startup.
#
# All profiles now use the AMD official image instead:
#   docker.io/vllm/vllm-openai-rocm:latest  (vLLM 0.22.1, ROCm 7.2)
#
# This file is retained for reference only.
FROM localhost/vllm-rdna4:rocm7.1.1-navi-fixed

RUN pip install --no-cache-dir \
    git+https://github.com/huggingface/transformers.git
